generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String?
  role      UserRole  @default(ADMIN)
  events    Event[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Event {
  id          Int        @id @default(autoincrement())
  title       String
  slug        String     @unique
  description String?
  startDate   DateTime
  endDate     DateTime
  location    String?
  organizerId Int
  organizer   User       @relation(fields: [organizerId], references: [id])
  sessions    Session[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Session {
  id          Int         @id @default(autoincrement())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  capacity    Int?
  eventId     Int
  event       Event       @relation(fields: [eventId], references: [id])
  roomId      Int
  room        Room        @relation(fields: [roomId], references: [id])
  speakers    Speaker[]
  questions   Question[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Room {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  sessions    Session[]
  createdAt   DateTime   @default(now())
}

model Speaker {
  id           Int         @id @default(autoincrement())
  fullName     String
  bio          String?
  photoUrl     String?
  linkedinUrl  String?
  twitterUrl   String?
  websiteUrl   String?
  sessions     Session[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Question {
  id           Int        @id @default(autoincrement())
  content      String
  authorName   String?
  upvotes      Int        @default(0)
  sessionId    Int
  session      Session    @relation(fields: [sessionId], references: [id])
  createdAt    DateTime   @default(now())
}